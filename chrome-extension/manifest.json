{
  "manifest_version": 3,
  "name": "Gesture Control",
  "version": "1.2",
  "description": "Control Chrome with hand gestures via webcam.",
  "permissions": ["scripting", "activeTab", "tabs", "alarms", "sidePanel"],
  "host_permissions": ["http://localhost/*"],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_icon": {
      "16": "assets/icon-192.png",
      "48": "assets/icon-192.png",
      "128": "assets/icon-192.png"
    }
  },
  "icons": {
    "16": "assets/icon-192.png",
    "48": "assets/icon-192.png",
    "128": "assets/icon-192.png"
  }
}
